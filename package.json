{
  "name": "garment-erp-new",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --outDir build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --project=setup --project=chromium --workers=1",
    "test:e2e:admin": "playwright test --project=admin-setup --project=admin --workers=1",
    "test:ui-review": "playwright test tests/e2e/ui-review.spec.ts --project=admin-setup --project=admin --workers=1",
    "test:e2e:all": "playwright test --workers=1",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed --workers=1",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:mobile": "playwright test --project=setup --project=mobile-chrome --workers=1",
    "test:e2e:report": "playwright show-report tests/playwright-report",
    "test": "npm run test:unit && npm run test:e2e",
    "load:smoke": "bash tests/load/run.sh smoke",
    "load:test": "bash tests/load/run.sh load",
    "load:stress": "bash tests/load/run.sh stress",
    "load:100k": "bash tests/load/run.sh 100k"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@supabase/supabase-js": "2.89.0",
    "@tiptap/extension-character-count": "^3.22.5",
    "@tiptap/extension-color": "^3.20.1",
    "@tiptap/extension-dropcursor": "^3.20.1",
    "@tiptap/extension-font-family": "^3.20.1",
    "@tiptap/extension-highlight": "^3.20.1",
    "@tiptap/extension-horizontal-rule": "^3.22.5",
    "@tiptap/extension-image": "^3.20.1",
    "@tiptap/extension-link": "^3.20.1",
    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/extension-table": "^3.22.5",
    "@tiptap/extension-table-cell": "^3.22.5",
    "@tiptap/extension-table-header": "^3.22.5",
    "@tiptap/extension-table-row": "^3.22.5",
    "@tiptap/extension-task-item": "^3.22.5",
    "@tiptap/extension-task-list": "^3.22.5",
    "@tiptap/extension-text-align": "^3.20.1",
    "@tiptap/extension-text-style": "^3.20.1",
    "@tiptap/extension-typography": "^3.22.5",
    "@tiptap/extension-underline": "^3.20.1",
    "@tiptap/pm": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "@tiptap/suggestion": "^3.22.5",
    "@types/react-simple-maps": "^3.0.6",
    "canvas-confetti": "^1.9.4",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.525.0",
    "prop-types": "^15.8.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-helmet-async": "^3.0.0",
    "react-is": "^18.3.1",
    "react-router-dom": "^7.14.2",
    "react-simple-maps": "^3.0.0",
    "recharts": "^3.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.1.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-remove-properties": "^0.3.1",
    "docx": "^9.6.1",
    "dotenv": "^17.4.2",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.9.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.5"
  }
